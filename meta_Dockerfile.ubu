ARG UBUNTU_DIST=noble
FROM ubuntu:$UBUNTU_DIST

ARG ZIG_VERSION
ARG UBUNTU_DIST
ARG BUILD_VERSION
ARG FULL_VERSION

RUN mkdir -p /output/DEBIAN

COPY packages/zls/output/DEBIAN/control /output/DEBIAN/

RUN sed -i "s/DIST/$UBUNTU_DIST/" /output/DEBIAN/control
RUN sed -i "s/BUILD_VERSION/$BUILD_VERSION/" /output/DEBIAN/control
RUN sed -i "s/ZIG_VERSION/$ZIG_VERSION/" /output/DEBIAN/control

RUN dpkg-deb --build /output /zls_$FULL_VERSION.deb


