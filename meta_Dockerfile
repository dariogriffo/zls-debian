FROM debian:trixie

ARG ZLS_VERSION
ARG DEBIAN_DIST
ARG BUILD_VERSION
ARG FULL_VERSION
ARG DEB_ARCH=amd64

RUN mkdir -p /output/DEBIAN

COPY packages/zls/output/DEBIAN/control /output/DEBIAN/

RUN sed -i "s/DIST/$DEBIAN_DIST/" /output/DEBIAN/control
RUN sed -i "s/BUILD_VERSION/$BUILD_VERSION/" /output/DEBIAN/control
RUN sed -i "s/ZLS_VERSION/$ZLS_VERSION/" /output/DEBIAN/control
RUN sed -i "s/DEB_ARCH/$DEB_ARCH/" /output/DEBIAN/control

RUN dpkg-deb --build /output /zls_$FULL_VERSION.deb


